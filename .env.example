# Copy to .env and replace every generated secret before starting Compose.
TZ=Europe/Paris
PLEXARR_IMAGE=mrcryllix/plex-rss:latest
POSTGRES_DB=plexrss
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Generate this value with the command documented in README.md and docs/OPERATIONS.md.
PLEXARR_ENCRYPTION_KEY=
ARQ_MAX_JOBS=4
ARQ_JOB_TIMEOUT=3600
BACKUP_RETENTION_DAYS=14
# On first PostgreSQL startup, import data/plex_rss.db only if PostgreSQL is empty.
AUTO_MIGRATE_LEGACY_SQLITE=1
LEGACY_SQLITE_PATH=/app/data/plex_rss.db
LEGACY_IMPORT_MAX_BYTES=268435456
